---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Impressum">
    <main class="max-w-3xl mx-auto px-6 py-20">
        <header class="mb-12">
            <h1 class="text-4xl font-extrabold text-white mb-4">Impressum</h1>
            <div class="h-1 w-20 bg-gradient-to-r from-brand-primary to-brand-secondary rounded-full"></div>
        </header>

        <div class="space-y-10 bg-slate-900/50 border border-slate-800 p-8 md:p-12 rounded-3xl shadow-2xl text-slate-300">
            <section>
                <h2 class="text-sm font-bold text-brand-primary uppercase tracking-widest mb-4">Angaben gemäß § 5 TMG</h2>
                <p class="text-white font-semibold text-lg">Shing-Kong Man</p>
                <p>G-Programmieren-Test-Str. 1 (Platzhalter)</p>
                <p>44135 Dortmund</p>
            </section>

            <section>
                <h2 class="text-sm font-bold text-brand-secondary uppercase tracking-widest mb-4">Kontakt</h2>
                <div class="space-y-2">
                    <p class="flex items-center gap-3">
                        <span class="text-slate-500">✉️</span> skm79925+EhrenCode@gmail.com
                    </p>
                </div>
            </section>

            <section class="pt-6 border-t border-slate-800 text-sm text-slate-500 italic">
                <p>Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV: Shing-Kong Man</p>
            </section>
        </div>
    </main>
</MainLayout>