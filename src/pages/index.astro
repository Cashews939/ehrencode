---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Digitales Ehrenamt | Web-Modernisierung für Vereine">
    <header class="container mx-auto px-6 pt-20 pb-16 text-center">
        <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight">
            Digitaler Rückenwind für <br>
            <span class="bg-gradient-to-r from-brand-primary to-brand-secondary bg-clip-text text-transparent">
                deinen Verein.
            </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
            Ich unterstütze Vereine und Ehrenämter dabei, ihre digitale Präsenz zu modernisieren – 
            ehrenamtlich, professionell und mit Leidenschaft für den guten Zweck.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="#kontakt" class="bg-brand-primary hover:scale-105 transition-all text-white px-8 py-4 rounded-2xl font-bold text-lg glow-hover">
                Jetzt Projekt anfragen
            </a>
            <a href="/projekte" class="bg-slate-900 border border-slate-800 hover:bg-slate-800 transition text-white px-8 py-4 rounded-2xl font-bold text-lg">
                Referenzen ansehen
            </a>
        </div>
    </header>

    <section class="container mx-auto px-6 py-24 border-t border-slate-900">
        <div class="grid md:grid-cols-3 gap-12">
            <div class="p-8 bg-slate-900/50 border border-slate-800 rounded-3xl">
                <div class="w-12 h-12 bg-brand-primary/20 rounded-2xl flex items-center justify-center text-brand-primary text-2xl mb-6">🚀</div>
                <h3 class="text-xl font-bold text-white mb-4">Modernisierung</h3>
                <p class="text-slate-400 leading-relaxed">Veraltete Webseiten bringe ich auf den neuesten Stand der Technik – schnell, sicher und mobil optimiert.</p>
            </div>
            <div class="p-8 bg-slate-900/50 border border-slate-800 rounded-3xl">
                <div class="w-12 h-12 bg-brand-secondary/20 rounded-2xl flex items-center justify-center text-brand-secondary text-2xl mb-6">🤝</div>
                <h3 class="text-xl font-bold text-white mb-4">Ehrenamtlich</h3>
                <p class="text-slate-400 leading-relaxed">Mein Beitrag zur Gesellschaft: Für gemeinnützige Vereine biete ich meine Expertise komplett kostenfrei an.</p>
            </div>
            <div class="p-8 bg-slate-900/50 border border-slate-800 rounded-3xl">
                <div class="w-12 h-12 bg-brand-primary/20 rounded-2xl flex items-center justify-center text-brand-primary text-2xl mb-6">🛠️</div>
                <h3 class="text-xl font-bold text-white mb-4">Wartungsfrei</h3>
                <p class="text-slate-400 leading-relaxed">Ich setze auf moderne Tools, die für euch einfach zu bedienen sind und keine teuren Serverkosten verursachen.</p>
            </div>
        </div>
    </section>

    <section id="kontakt" class="py-24 relative overflow-hidden">
        <div class="container mx-auto px-6 max-w-4xl">
            <div class="bg-slate-900/50 border border-slate-800 p-8 md:p-12 rounded-[3rem] shadow-2xl">
                <h2 class="text-3xl font-bold text-white mb-2 text-center">Lass uns was bewegen</h2>
                <p class="text-slate-400 text-center mb-10">Hast du ein Projekt oder eine Frage? Schreib mir einfach!</p>

                <form id="contact-form" action="https://formspree.io/f/xwvalrzw" method="POST" class="space-y-6">
                    <input type="text" name="_gotcha" style="display:none" />
                    
                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label for="name" class="text-sm font-semibold text-slate-300 ml-1">Dein Name</label>
                            <input type="text" name="name" id="name" required class="w-full bg-slate-950 border border-slate-800 rounded-2xl px-5 py-3 text-white focus:border-brand-primary outline-none transition" placeholder="Vor- & Nachname">
                        </div>
                        <div class="space-y-2">
                            <label for="email" class="text-sm font-semibold text-slate-300 ml-1">Deine E-Mail</label>
                            <input type="email" name="email" id="email" required class="w-full bg-slate-950 border border-slate-800 rounded-2xl px-5 py-3 text-white focus:border-brand-primary outline-none transition" placeholder="name@beispiel.de">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="message" class="text-sm font-semibold text-slate-300 ml-1">Deine Nachricht</label>
                        <textarea name="message" id="message" rows="5" required class="w-full bg-slate-950 border border-slate-800 rounded-2xl px-5 py-3 text-white focus:border-brand-primary outline-none transition" placeholder="Wie kann ich helfen?"></textarea>
                    </div>

                    <button type="submit" id="submit-btn" class="w-full bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-bold py-4 rounded-2xl hover:scale-[1.02] transition-all shadow-lg shadow-brand-primary/20">
                        Nachricht absenden
                    </button>
                    <p id="status" class="text-center text-sm mt-4"></p>
                </form>

                <script is:inline>
                const form = document.getElementById("contact-form");
                const status = document.getElementById("status");
                const btn = document.getElementById("submit-btn");

                form.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    btn.disabled = true;
                    btn.innerText = "Wird gesendet...";
                    
                    const data = new FormData(form);
                    const response = await fetch(form.action, {
                    method: 'POST',
                    body: data,
                    headers: { 'Accept': 'application/json' }
                    });

                    if (response.ok) {
                    // HIER passiert die Magie: Wir leiten selbst weiter!
                    window.location.href = "/danke";
                    } else {
                    status.innerHTML = "Ups! Da gab es ein Problem. Versuch es bitte nochmal.";
                    btn.disabled = false;
                    btn.innerText = "Nachricht absenden";
                    }
                });
                </script>
            </div>
        </div>
    </section>
</MainLayout>