---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Danke für deine Nachricht">
    <section class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6">
        <div class="w-20 h-20 bg-brand-primary/20 rounded-3xl flex items-center justify-center text-4xl mb-8 animate-bounce">
            ✉️
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
            Nachricht <span class="bg-gradient-to-r from-brand-primary to-brand-secondary bg-clip-text text-transparent">erhalten!</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-lg mx-auto mb-10 leading-relaxed">
            Vielen Dank für dein Interesse! Ich habe deine Nachricht erhalten und melde mich zeitnah bei dir, um über dein Projekt zu sprechen.
        </p>
        <a href="/" class="bg-slate-900 border border-slate-800 hover:bg-slate-800 transition text-white px-8 py-4 rounded-2xl font-bold text-lg">
            Zurück zur Startseite
        </a>
    </section>
</MainLayout>