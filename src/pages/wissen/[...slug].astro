---
import { getCollection, render } from 'astro:content'; 
import MainLayout from '../../layouts/MainLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const wissenEntries = await getCollection('wissen');
  return wissenEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description, thumbnail } = entry.data;
const { Content } = await render(entry);

console.log("Das ist mein Thumbnail:", thumbnail);
---

<MainLayout title={title}>
  <main class="max-w-3xl mx-auto px-6 py-20">
    
    <div class="mb-12">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 text-slate-400 hover:text-brand-primary transition-colors group"
      >
        <div class="w-8 h-8 rounded-full border border-slate-800 flex items-center justify-center group-hover:border-brand-primary/50 group-hover:bg-brand-primary/10 transition-all">
          <svg 
            class="w-4 h-4 rotate-180 transform group-hover:-translate-x-1 transition-transform" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
          >
            <path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
        <span class="text-sm font-medium">Zurück zur Übersicht</span>
      </a>
    </div>

    {thumbnail && (
      <div class="mb-10">
        <Image 
          src={thumbnail} 
          alt={title} 
          width={1200} 
          height={675} 
          class="rounded-3xl shadow-2xl border border-white/5 object-cover aspect-video"
        />
      </div>
    )}

    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        {title}
      </h1>
      <p class="text-xl text-slate-400 leading-relaxed">
        {description}
      </p>
    </header>

    <article class="prose prose-invert prose-slate max-w-none 
      prose-headings:text-white 
      prose-a:text-brand-primary 
      prose-strong:text-white 
      prose-img:rounded-3xl">
      
      <Content />
      
    </article>

    <div class="mt-20 pt-8 border-t border-slate-900 text-center">
      <p class="text-slate-500 text-sm">
        Hast du Fragen zu diesem Thema? <a href="/#kontakt" class="text-brand-primary hover:underline">Schreib mir einfach.</a>
      </p>
    </div>
  </main>
</MainLayout>