---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="https://fav.farm/🎗️">
    <title>{title} | EhrenCode</title>
</head>

<body class="bg-slate-950 text-slate-200 flex flex-col min-h-screen relative">
    
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-brand-primary/10 blur-[120px]"></div>
        
        <div class="absolute top-[30%] -right-[10%] w-[40%] h-[40%] rounded-full bg-brand-secondary/10 blur-[120px]"></div>

        <div class="absolute bottom-0 left-[20%] w-[30%] h-[30%] rounded-full bg-brand-primary/5 blur-[100px]"></div>
    </div>

    <Header />
    
    <main class="flex-grow">
        <slot />
    </main>

    <Footer />

</body>
</html>