---
// src/components/Footer.astro
---
<footer class="py-4 border-t border-slate-900 bg-slate-950">
  <div class="container mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-4">
    
    <div class="flex items-center gap-5 text-xs sm:text-sm text-slate-400">
      <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
      <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
      
      <a 
        href="https://www.linkedin.com/in/DEIN-PROFIL" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="flex items-center gap-1.5 hover:text-white transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
        <span>LinkedIn</span>
      </a>
    </div>

    <p class="text-[10px] sm:text-xs text-slate-600 uppercase tracking-widest">
      &copy; {new Date().getFullYear()} EhrenCode
    </p>
  </div>
</footer>