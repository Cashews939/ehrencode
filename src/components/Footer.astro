---
// src/components/Footer.astro
---
<footer class="py-4 border-t border-slate-900 bg-slate-950">
    <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
            
            <div class="flex items-center gap-3 text-xs">
                <span class="font-bold bg-gradient-to-r from-brand-primary to-brand-secondary bg-clip-text text-transparent">
                    EhrenCode n.e.V.
                </span>
                <span class="text-slate-600">|</span>
                <span class="text-slate-500">
                    &copy; {new Date().getFullYear()}
                </span>
            </div>

            <nav class="flex gap-6 text-[10px] uppercase tracking-widest font-semibold text-slate-500">
                <a href="/impressum" class="hover:text-slate-300 transition-colors">Impressum</a>
                <a href="/datenschutz" class="hover:text-slate-300 transition-colors">Datenschutz</a>
            </nav>

        </div>
    </div>
</footer>